<IfModule mod_headers.c>
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
  Header always set Access-Control-Allow-Headers "Authorization, Content-Type, X-Client-Info, apikey"
  Header always set Access-Control-Max-Age "3600"

  # Responder OK a preflight OPTIONS
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^ - [R=200,L]
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirigir todas las solicitudes a index.html si el archivo/directorio no existe
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [QSA,L]
  
  # Permitir acceso a archivos estáticos
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [QSA,L]
  
  # Permitir acceso a directorios
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [QSA,L]
</IfModule>
